    "react-plotly.js": "^2.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "pg": "^8.16.3",
    "posthog-js": "^1.312.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsne-js": "^1.0.3",
